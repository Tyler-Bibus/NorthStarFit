<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvExcersise"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Exercise"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.077"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Spinner
        android:id="@+id/spExcercise"
        android:layout_width="93dp"
        android:layout_height="52dp"
        android:layout_marginStart="30dp"
        android:entries="@array/movements"
        android:spinnerMode="dropdown"
        app:layout_constraintBottom_toBottomOf="@+id/tvExcersise"
        app:layout_constraintStart_toEndOf="@+id/tvExcersise"
        app:layout_constraintTop_toTopOf="@+id/tvExcersise" />

    <TextView
        android:id="@+id/tvSetsCompleted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="28dp"
        android:text="Sets: 19"
        app:layout_constraintStart_toStartOf="@+id/tvExcersise"
        app:layout_constraintTop_toBottomOf="@+id/tvExcersise" />

    <TextView
        android:id="@+id/tvTotalVolume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        android:text="Volume: 100"
        app:layout_constraintBottom_toBottomOf="@+id/tvSetsCompleted"
        app:layout_constraintStart_toEndOf="@+id/tvSetsCompleted"
        app:layout_constraintTop_toTopOf="@+id/tvSetsCompleted"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tvTotalReps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        android:text="Reps: 100"
        app:layout_constraintBottom_toBottomOf="@+id/tvTotalVolume"
        app:layout_constraintStart_toEndOf="@+id/tvTotalVolume"
        app:layout_constraintTop_toTopOf="@+id/tvTotalVolume" />

    <Button
        android:id="@+id/btAddMovement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:text="Add Mvmt"
        app:layout_constraintBottom_toBottomOf="@+id/spExcercise"
        app:layout_constraintStart_toEndOf="@+id/spExcercise"
        app:layout_constraintTop_toTopOf="@+id/spExcercise"
        app:layout_constraintVertical_bias="1.0" />

    <ScrollView
        android:id="@+id/svSets"
        android:layout_width="412dp"
        android:layout_height="550dp"
        android:layout_marginTop="124dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/btEndWorkout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:text="End Workout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>