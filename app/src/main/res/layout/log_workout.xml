<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <EditText
        android:id="@+id/etReps"
        android:layout_width="181dp"
        android:layout_height="53dp"
        android:layout_marginStart="12dp"
        android:ems="10"
        android:hint="Reps"
        android:inputType="number"
        android:textColorHint="#B3B2B2"
        app:layout_constraintStart_toEndOf="@+id/etWeight"
        app:layout_constraintTop_toTopOf="@+id/etWeight" />

    <TextView
        android:id="@+id/tvExcersise"
        android:layout_width="89dp"
        android:layout_height="22dp"
        android:layout_marginTop="28dp"
        android:text="Exercise"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.077"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btSubmitExcercise"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:text="Set Complete"
        app:layout_constraintBottom_toBottomOf="@+id/spExcercise"
        app:layout_constraintStart_toEndOf="@+id/spExcercise"
        app:layout_constraintTop_toTopOf="@+id/spExcercise" />

    <Spinner
        android:id="@+id/spExcercise"
        android:layout_width="93dp"
        android:layout_height="52dp"
        android:layout_marginStart="30dp"
        android:entries="@array/movements"
        android:spinnerMode="dropdown"
        app:layout_constraintBottom_toBottomOf="@+id/tvExcersise"
        app:layout_constraintStart_toEndOf="@+id/tvExcersise"
        app:layout_constraintTop_toTopOf="@+id/tvExcersise" />

    <TextView
        android:id="@+id/tvSetsCompleted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="128dp"
        android:text="Sets: 19"
        app:layout_constraintStart_toStartOf="@+id/tvExcersise"
        app:layout_constraintTop_toBottomOf="@+id/tvExcersise" />

    <EditText
        android:id="@+id/etWeight"
        android:layout_width="181dp"
        android:layout_height="53dp"
        android:layout_marginTop="20dp"
        android:ems="10"
        android:hint="Weight (lbs)"
        android:inputType="numberDecimal"
        android:textColorHint="#B3B2B2"
        app:layout_constraintStart_toStartOf="@+id/tvExcersise"
        app:layout_constraintTop_toBottomOf="@+id/spExcercise" />

    <TextView
        android:id="@+id/tvTotalVolume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="68dp"
        android:text="TextView"
        app:layout_constraintBottom_toBottomOf="@+id/tvSetsCompleted"
        app:layout_constraintStart_toEndOf="@+id/tvSetsCompleted"
        app:layout_constraintTop_toTopOf="@+id/tvSetsCompleted"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/tvTotalReps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:text="TextView"
        app:layout_constraintBottom_toBottomOf="@+id/tvTotalVolume"
        app:layout_constraintStart_toEndOf="@+id/tvTotalVolume"
        app:layout_constraintTop_toTopOf="@+id/tvTotalVolume" />

    <Button
        android:id="@+id/btAddMovement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:text="Add Mvmt"
        app:layout_constraintStart_toStartOf="@+id/etWeight"
        app:layout_constraintTop_toBottomOf="@+id/tvTotalReps" />

    <ScrollView
        android:id="@+id/svSets"
        android:layout_width="410dp"
        android:layout_height="382dp"
        android:layout_marginTop="348dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/btEndWorkout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:text="End Workout"
        app:layout_constraintStart_toEndOf="@+id/btAddMovement"
        app:layout_constraintTop_toTopOf="@+id/btAddMovement" />

</androidx.constraintlayout.widget.ConstraintLayout>